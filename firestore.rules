rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Public read — players, matchups, results, archives are all visible to anyone
    match /players/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /matchups/{id} {
      allow read: if true;
      // Allow score submission (PIN verified client-side) + admin writes
      allow write: if true;
    }

    match /results/{id} {
      allow read: if true;
      // Allow score submission
      allow write: if true;
    }

    match /archives/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /tournaments/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
